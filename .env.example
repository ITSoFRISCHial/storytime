# Google Cloud (ALL Google services: Gemini, Imagen, TTS)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# Paste service account JSON key as a single line, e.g.:
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"my-project","private_key_id":"abc123","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"storytime@my-project.iam.gserviceaccount.com",...}
GOOGLE_SERVICE_ACCOUNT_KEY=

# Claude (story generation)
ANTHROPIC_API_KEY=

# Vercel Blob (asset storage)
BLOB_READ_WRITE_TOKEN=

# Password gate
APP_GATE_KEY=
